GITHUB_TOKEN=ghp_your_token_here
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini
README_REFRESH_KEY=choose_a_strong_key
README_AUTO_REFRESH=false
README_REFRESH_INTERVAL_MIN=60
PROFILE_CACHE_TTL_SEC=300
BADGE_CACHE_TTL_SEC=120
README_ASSET_MODE=local
BADGE_LOCAL_PREFIX=./assets
BADGE_BASE_URL=https://omnizap.xyz
LOCAL_ASSET_SYNC_ENABLED=true
LOCAL_ASSET_SYNC_INTERVAL_HOURS=4
LOCAL_ASSET_SYNC_SCRIPT=scripts/publish-assets.js
LOCAL_RENDER_BASE_URL=http://127.0.0.1:3015
AUTO_PUSH_ENABLED=true
AUTO_PUSH_REMOTE=origin
AUTO_PUSH_STRICT=false
AUTO_PUBLISH_DRY_RUN=false
GITHUB_PUSH_TOKEN=ghp_your_push_token_here
README_PATH=/root/kaikybrofc/README.md
STACK_SCAN_MAX_REPOS=40
STACK_SCAN_CONCURRENCY=4
STACK_TOP_LIMIT=14
STACK_CURRENT_LIMIT=14
AI_ABOUT_REFRESH_HOURS=24
AI_ABOUT_CACHE_PATH=/root/kaikybrofc/.cache/ai-about.json
AI_FOCUS_REFRESH_HOURS=24
AI_FOCUS_CACHE_PATH=/root/kaikybrofc/.cache/ai-focus.json
AI_FOCUS_REPOS_MAX=5
AI_FOCUS_COMMITS_PER_REPO=3
AI_FOCUS_TOTAL_COMMITS=12
AI_FOCUS_MAX_OUTPUT_TOKENS=180
ADV_STATS_CACHE_PATH=/root/kaikybrofc/.cache/advanced-stats.json
ADV_STATS_REFRESH_HOURS=6
ADV_STATS_REPOS_MAX=8
ADV_STATS_COMMITS_PER_REPO=25
ADV_STATS_MERGED_PRS_SAMPLE=50
