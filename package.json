{
  "name": "perfil-server",
  "version": "1.0.0",
  "private": true,
  "description": "Express server for omnizap.xyz behind Nginx",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "refresh:readme": "node scripts/update-readme.js",
    "render:assets": "node scripts/render-assets.js",
    "publish:assets": "node scripts/publish-assets.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "simple-icons": "^16.11.0"
  }
}
